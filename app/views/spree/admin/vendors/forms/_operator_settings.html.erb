<div class="row mb-4">
  <div class="col-lg-4">
    <h5><%= Spree.t('vendor.operator_settings') %></h5>
    <p class="text-muted">
      This information isn't visible for Partners, only for the Operator.
    </p>
  </div>
  <div class="col-lg-7 offset-lg-1">
    <% if stripe_gateway.present? && @stripe_account.present?  %>
      <div class="form-group">
        <%= f.label :payouts_schedule_interval, 'Payouts schedule' %>
        <%= f.select :payouts_schedule_interval,
          options_for_select(stripe_vendor_payouts_schedule_interval_options, @stripe_account.payouts_interval),
          {},
          { class: 'custom-select' } %>
        <%= f.error_message_on :payouts_schedule_interval %>
        <p class="form-text text-muted">
          Marketplace default interval is set in
          <%= link_to 'General Settings', spree.edit_admin_store_path(section: 'general-settings', anchor: 'partners-payouts') %>
        </p>
      </div>
    <% end %>
    <div class="form-group">
      <%= f.label :platform_fee, 'Commission Rate' %>
      <div class="input-group">
        <%= f.number_field :platform_fee, class: 'form-control', step: 0.01, min: 0 %>
        <div class="input-group-append">
          <span class="input-group-text">%</span>
        </div>
      </div>
      <%= f.error_message_on :platform_fee %>
    </div>
  </div>
</div>
