<%= turbo_frame_tag "vendor_commision_rate_#{@vendor.id}" do %>
  <div class="alert alert-info">
    This will be the default commission rate for all products from this partner unless
    you specify a different rate for a specific product.
  </div>
  <%= form_for [:admin, @vendor] do |f| %>
    <div class="form-group">
      <%= f.label :platform_fee, 'Commission Rate' %>
      <div class="input-group">
        <%= f.number_field :platform_fee, class: 'form-control', step: 0.01, min: 0 %>
        <div class="input-group-append">
          <span class="input-group-text">%</span>
        </div>
      </div>
      <%= f.error_message_on :platform_fee %>
    </div>
    <div class="d-flex">
      <%= turbo_save_button_tag %>
      <%= link_to Spree.t('actions.discard'), spree.admin_vendor_path(@vendor, display_commission_rate: true), class: 'btn btn-light ml-2' %>
    </div>
  <% end %>
<% end %>
