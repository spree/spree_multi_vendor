<%= content_for :page_title do %>
  <%= Spree.t('admin.marketplace') %>
<% end %>

<%= content_for :page_actions do %>
  <%= turbo_save_button_tag Spree.t('actions.update'), class: 'btn btn-primary', form: "edit_store_#{current_store.id}" %>
<% end %>

<%= form_for current_store, url: spree.admin_marketplace_settings_path, method: :patch do |f| %>
  <div class="row">
    <div class="col-lg-6 offset-lg-3">
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title">Vendor Commission rate</h5>
        </div>
        <div class="card-body">
          <p class="text-muted">
            This is the default commission rate, you can override this value for
            each Partner, Category x Vendor and Vendor product.
          </p>
          <div class="alert alert-info">
            <p>
              This change will only apply to newly invited
              <%= link_to "Partners", spree.admin_vendors_path, class: "alert-link" %>. It will not change the commission rate for existing Partners.
            </p>
            <p>It will not change the commission rate for existing Partners.</p>
          </div>
          <div class="form-group">
            <%= f.label :preferred_platform_fee, "Commission rate" %>
            <div class="form-control d-flex align-items-center py-0 focus-shadow-blue">
              <%= f.number_field :preferred_platform_fee,
                            step: 0.1,
                            min: 0,
                            class: "form-control-plaintext pl-0" %>
              <span>%</span>
            </div>
            <%= f.error_message_on :preferred_platform_fee %>
          </div>
        </div>
      </div>

      <% if defined?(SpreeStripe::Gateway) %>
        <div class="card mb-4">
          <div class="card-header">
            <h5 class="card-title">Vendor Payouts</h5>
          </div>
          <div class="card-body">
            <p class="text-muted">
              This controls how often your Vendors will be able to request a payout
              in Stripe dashboard.
            </p>
            <div class="alert alert-info">
              <p>
                Changing this option will also change payout schedules for your
                existing Vendors with the payout schedule set to
                <strong>Use marketplace default interval</strong>.
              </p>
            </div>
            <div class="form-group">
              <%= f.label :preferred_vendor_payouts_schedule_interval,
                      Spree.t(:preferred_vendor_payouts_schedule_interval) %>
              <%= f.select :preferred_vendor_payouts_schedule_interval,
                      options_for_select(
                        stripe_store_payouts_schedule_interval_options,
                        f.object.preferred_vendor_payouts_schedule_interval,
                      ),
                      {},
                      { class: "custom-select" } %>
              <%= f.error_message_on :preferred_vendor_payouts_schedule_interval %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title">Shopify App</h5>
        </div>
        <div class="card-body pb-0">
          <div class="form-group">
            <div>
              <%= f.label :shopify_app_image, class: 'form-label' %>
            </div>
            <%= render 'active_storage/upload_form', form: f, field_name: :shopify_app_image, width: 600, height: 300, crop: true %>
            <p class="text-muted mt-2">
              This image will be displayed in the Shopify App when merchants install the app.
            </p>
          </div>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title">Terms of Service</h5>
        </div>
        <div class="card-body pb-0">
          <div class="trix-container">
            <%= f.rich_text_area :vendor_terms_of_service %>
          </div>
          <p class="text-muted mt-2">
            This will be displayed to Vendors when they are invited to the marketplace.
          </p>
        </div>
      </div>
    </div>
  </div>
<% end %>