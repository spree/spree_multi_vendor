<li class="list-group-item d-flex justify-content-between align-items-center">
  <%= link_to suborder.number, spree.edit_admin_order_path(suborder), class: 'text-dark font-weight-bold d-block w-20' %>
  <div class="w-20 align-items-center">
    <% if suborder.vendor.present? %>
      <%= vendor_logo_link(suborder.vendor, height: 20) %>
    <% end %>
  </div>
  <% if suborder.payment_state %>
    <div class="w-20 align-items-center d-none d-lg-block text-center">
      <%= order_payment_state(suborder) %>
      <% if suborder.transfer_failed_error.present? %>
        <span class="badge  badge-danger">
          Transfer failed
        </span>
      <% end %>
    </div>
  <% end %>
  <% if suborder.shipment_state %>
    <div class="w-20 align-items-center d-none d-lg-block text-center">
      <%= order_shipment_state(suborder) %>
    </div>
  <% end %>
  <span class="text-right w-20">
    <%= suborder.display_total %>

    <span class="text-muted small d-block">
      <%= Spree.t(:commission_total) %>:
      <%= suborder.display_platform_fee_total.abs %>
    </span>
  </span>
</li>
